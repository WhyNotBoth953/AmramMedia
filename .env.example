# General
TZ=Asia/Jerusalem
CONFIG_PATH=/home/amram/amram-media/config

# Plex
PLEX_CLAIM=claim-XXXXXXXXXXXXXXXXXXXX   # Get from https://plex.tv/claim (expires in 4 min)
PLEX_TOKEN=                              # Get after setup from Plex settings XML

# Sonarr
SONARR_API_KEY=                          # Get from Sonarr UI -> Settings -> General

# Radarr
RADARR_API_KEY=                          # Get from Radarr UI -> Settings -> General

# qBittorrent
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin          # Change after first login!

# Prowlarr
PROWLARR_API_KEY=                        # Get from Prowlarr UI -> Settings -> General

# Telegram Bot
TELEGRAM_BOT_TOKEN=                      # From @BotFather on Telegram
TELEGRAM_ALLOWED_CHAT_IDS=               # Comma-separated chat IDs (get yours from @userinfobot)

# Bazarr
BAZARR_API_KEY=                          # Get from Bazarr UI -> Settings -> General
